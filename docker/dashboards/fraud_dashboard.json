{
  "title": "Real-Time Fraud Detection",
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "stat",
      "title": "Ingestion Throughput",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(feature_store_ingestion_total[1m])",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "stat",
      "title": "Inference Throughput",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "rate(inference_requests_total[1m])",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "stat",
      "title": "Fraud Detected",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total{decision=\"DECLINE\"}[1m])) / sum(rate(inference_requests_total[1m])) * 100",
          "legendFormat": "Fraud Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Decisions Over Time",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "sum by (decision) (rate(inference_requests_total[1m]))",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99 Inference Latency"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(feature_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99 Feature Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ]
}
